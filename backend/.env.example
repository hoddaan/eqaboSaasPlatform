# ── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ──────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/eqabo
# For Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/eqabo

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_too
JWT_REFRESH_EXPIRES_IN=30d

# ── Frontend URL (CORS) ──────────────────────────────
CLIENT_URL=http://localhost:4200

# ── Email (for partner receipts) ─────────────────────
GMAIL_USER=your_gmail@gmail.com
GMAIL_PASS=your_app_password_16_chars
# Generate app password: Google Account > Security > App passwords

# ── File Upload ──────────────────────────────────────
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# ── Super Admin Seed (first run) ─────────────────────
SEED_ADMIN_EMAIL=superadmin@eqabo.com
SEED_ADMIN_PASSWORD=Admin@1234
